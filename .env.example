# ==============================================================================
# AI-Powered GitHub PR Review System Configuration Template
# Copy this file to '.env' and populate with your credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# GitHub REST API Settings
# ------------------------------------------------------------------------------
# GitHub Personal Access Token (PAT) or Actions runner token with 'pull-requests: write' access.
GITHUB_TOKEN=your_github_token_here

# Repository path in standard 'owner/repository' format.
# Example: AcmeOrg/enterprise-backend
GITHUB_REPOSITORY=owner/repository

# The target Pull Request number to review.
# In GitHub Actions, this is automatically retrieved from the workflow context event.
GITHUB_PR_NUMBER=123

# ------------------------------------------------------------------------------
# Gemini REST API Settings
# ------------------------------------------------------------------------------
# Google AI Studio Gemini API Key.
GEMINI_API_KEY=your_gemini_api_key_here

# The Gemini model name to use for content generation.
# Supported models include: gemini-1.5-flash, gemini-1.5-pro, etc.
GEMINI_MODEL_NAME=gemini-1.5-flash

# Temperature settings controlling output randomness.
# Value must be between 0.0 (deterministic) and 1.0 (creative).
GEMINI_TEMPERATURE=0.1

# ------------------------------------------------------------------------------
# Code Review exclusions & limits
# ------------------------------------------------------------------------------
# JSON array specifying glob exclusion rules to skip files from AI analysis.
# Escape backslashes if defining custom separators.
EXCLUDE_PATHS=["**/bin/**", "**/obj/**", "**/*.g.cs", "**/*.Designer.cs"]

# Cap on maximum inline comments posted by the agent to prevent spamming PR reviews.
# Must be between 1 and 100.
MAX_COMMENTS_PER_PR=30

# ------------------------------------------------------------------------------
# Logging & Debugging Settings
# ------------------------------------------------------------------------------
# Structured logging output level.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Runtime & dry-run Settings
# ------------------------------------------------------------------------------
# Toggle dry-run execution mode.
# If set to 'true', the review engine parses diffs and queries Gemini,
# but prints inline comments and reports to stdout logs instead of posting to GitHub.
DRY_RUN=false
